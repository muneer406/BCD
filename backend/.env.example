# BCD Backend — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# ── Supabase (required) ─────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── JWT Configuration ───────────────────────────────────────────────────────
# Supabase uses ES256 (Elliptic Curve). Do not change unless Supabase defaults change.
JWT_ALGORITHM=ES256

# ── Server ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api

# ── CORS (required for production) ──────────────────────────────────────────
# Comma-separated list of allowed origins.
# Example: https://app.example.com,https://staging.example.com
# WARNING: No default — if empty, all cross-origin requests will be blocked.
# A startup warning is logged if set to "*" (development only).
ALLOWED_ORIGINS=*

# ── Rate Limiting ───────────────────────────────────────────────────────────
# Max analyze-session calls per day per IP address
RATE_LIMIT_ANALYSIS_PER_DAY=20

# ── Magic Link Backdoor (DEVELOPMENT ONLY) ─────────────────────────────────
# Password for the /api/generateLink development-only endpoint.
# If empty/unset, the endpoint returns 503 (disabled).
# Do NOT set this in production — it lets anyone authenticate as any user.
BACKDOOR_PASSWORD=

# ── Migration Runner ────────────────────────────────────────────────────────
# Optional: direct database connection string for scripted migrations.
# If unset, migrations must be run manually via Supabase Dashboard SQL Editor.
# SUPABASE_DB_CONNECTION=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Optional: Supabase Management API token for automated migration execution.
# Generate at: Supabase Dashboard → Settings → API → Service Token
# SUPABASE_ACCESS_TOKEN=sbp_your_management_token_here
