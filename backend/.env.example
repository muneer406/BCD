# BCD Backend — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# Supabase project credentials (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT: Supabase uses ES256 (Elliptic Curve)
JWT_ALGORITHM=ES256

# Server configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api

# CORS: comma-separated origins, or "*" for development
# Example: https://app.example.com,https://staging.example.com
ALLOWED_ORIGINS=*

# Rate limiting: max analyze-session calls per day per IP
RATE_LIMIT_ANALYSIS_PER_DAY=20

# Magic link backdoor: only needed if you use /api/generateLink
# Leave empty to disable the endpoint (returns 503)
BACKDOOR_PASSWORD=
