# BCD Frontend — Environment Configuration
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Supabase project URL (required)
# Found in: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=

# Supabase anonymous/public key (required)
# Found in: Supabase Dashboard → Settings → API → anon public
# This key is safe for client-side use (RLS prevents unauthorized access)
VITE_SUPABASE_ANON_KEY=

# Backend API URL (required)
# For local development: http://localhost:8000
# For production: Your deployed backend URL (e.g., HF Space URL)
# If unset, API calls will fail with a descriptive error
VITE_API_URL=http://localhost:8000
